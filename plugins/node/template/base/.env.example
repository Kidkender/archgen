# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://root:root@localhost:3306/{{PROJECT_NAME}}

# Redis (optional)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000
